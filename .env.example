# Copy this file to .env and fill in your values.
# In a GitHub Codespace, set these as Codespace Secrets instead.
# Never commit .env to version control.

# Registered AmeriFlux account name (required)
AMERIFLUX_USER_NAME=

# Registered AmeriFlux account email (required)
AMERIFLUX_USER_EMAIL=

# AmeriFlux intended use code (1–6); default 1 = network synthesis analysis
# 1 = Synthesis / network synthesis analysis
# 2 = Model
# 3 = Remote sensing
# 4 = Other research
# 5 = Education
# 6 = Other
AMERIFLUX_INTENDED_USE=1

# Expected fluxnet-shuttle version; pipeline warns if installed version differs
FLUXNET_SHUTTLE_VERSION=0.3.7

# Snapshot mode: "development" (re-download) or "locked" (use snapshot CSV)
FLUXNET_SNAPSHOT_MODE=development

# Path to locked snapshot CSV; required when FLUXNET_SNAPSHOT_MODE="locked"
FLUXNET_SNAPSHOT_FILE=

# Root directory for all pipeline data (raw, extracted, processed, snapshots).
# Override to redirect data I/O to HPC scratch or an external volume.
# Default: "data" (relative to project root — standard Codespace layout).
FLUXNET_DATA_ROOT=data

# Site filter: space-separated list of site IDs to restrict the pipeline to.
# When unset (default), all sites in the manifest/snapshot are processed.
# Set this during development/testing to work with a subset of sites.
# Example: FLUXNET_SITE_FILTER=DK-Sor CA-Mer AU-Wom
FLUXNET_SITE_FILTER=

# Temporal resolutions to extract from downloaded zips (space-separated).
# Valid tokens: y (yearly), m (monthly), w (weekly), d (daily), h (half-hourly/hourly)
# Default: "y m d" — the Annual Paper uses YY, MM, and DD only.
# Set to "y m w d h" to extract all resolutions.
FLUXNET_EXTRACT_RESOLUTIONS=y m d

# Delete ZIP files after extraction (TRUE/FALSE, default TRUE).
# When TRUE, each ZIP in data/raw/ is deleted immediately after at least one
# file has been successfully extracted from it. Reduces peak disk usage during
# batch downloads. Set to FALSE to retain raw ZIPs for debugging or re-extraction.
FLUXNET_DELETE_ZIPS=TRUE
